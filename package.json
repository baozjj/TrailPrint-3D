{
  "name": "trailprint-3d",
  "version": "0.1.0",
  "description": "印迹 TrailPrint 3D — GPX 轨迹转 3D 地形纪念碑",
  "main": "./out/main/index.js",
  "author": "TrailPrint",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 electron-vite dev",
    "build": "electron-vite build",
    "preview": "NODE_OPTIONS=--max-old-space-size=8192 electron-vite preview",
    "package": "npm run build && electron-builder",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json --composite false && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "geotiff": "^3.0.5",
    "leaflet": "^1.9.4",
    "leaflet-rotate": "^0.2.8",
    "pinia": "2.3.1",
    "three": "^0.184.0",
    "three-bvh-csg": "^0.0.18",
    "vue": "3.5.13"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/leaflet": "^1.9.15",
    "@types/node": "22.14.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-vue": "5.2.3",
    "electron": "35.1.5",
    "electron-builder": "26.0.12",
    "electron-vite": "3.1.0",
    "typescript": "5.8.3",
    "vite": "6.3.2",
    "vue-tsc": "2.2.8"
  },
  "build": {
    "appId": "com.trailprint.app",
    "productName": "TrailPrint 3D",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
